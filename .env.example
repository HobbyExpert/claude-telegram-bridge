# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — send /id to the bot to find it
# Comma-separated for multiple users
ALLOWED_USER_IDS=

# Default working directory
DEFAULT_CWD=/Users/santibm/Sites

# Max USD per task (default 2.00)
DEFAULT_BUDGET_USD=2.0

# Max agentic turns per task
DEFAULT_MAX_TURNS=10

# Timeout in seconds (default 5 min)
TASK_TIMEOUT_SECONDS=300

# Full path to claude binary
CLAUDE_BIN=/Users/santibm/.local/bin/claude
